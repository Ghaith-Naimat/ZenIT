<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZenIT.Mac.App.ViewModels"
        x:Class="ZenIT.Mac.App.MainWindow"
        Title="ZenIT | Self-Service IT Assistant"
        Width="1280" Height="840"
        MinWidth="1080" MinHeight="700"
        Background="{StaticResource ZenBackgroundBrush}"
        FlowDirection="{Binding AppFlowDirection}"
        WindowStartupLocation="CenterScreen">

  <Window.DataTemplates>
    <!-- Workflow card -->
    <DataTemplate DataType="{x:Type vm:WorkflowCardViewModel}">
      <Border Width="300" Margin="0 0 14 14" Padding="16" CornerRadius="14"
              Background="{Binding CardBackground, Converter={StaticResource BrushConv}}"
              BorderBrush="{Binding CardBorderBrush, Converter={StaticResource BrushConv}}"
              BorderThickness="1" BoxShadow="0 6 18 0 #10172B3A">
        <StackPanel Spacing="8">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <Border Grid.Column="0" Background="#E7F7F7" CornerRadius="9" Padding="8 4" MinWidth="42">
              <TextBlock Text="{Binding IconText}" Foreground="{StaticResource ZenDeepTealBrush}"
                         FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" />
            </Border>
            <Border Grid.Column="2" Background="#F0FAF7" CornerRadius="9" Padding="8 4"
                    IsVisible="{Binding HasBadge}">
              <TextBlock Text="{Binding BadgeText}" Foreground="{StaticResource ZenSuccessBrush}"
                         FontSize="11" FontWeight="SemiBold" />
            </Border>
          </Grid>
          <TextBlock Text="{Binding Title}" Classes="h2" TextWrapping="Wrap" />
          <TextBlock Text="{Binding Description}" Classes="muted" TextWrapping="Wrap" MinHeight="30" />
          <Button Classes="primary" HorizontalAlignment="Stretch"
                  Content="{Binding ButtonText}" Command="{Binding RunCommand}" />
          <TextBlock Text="{Binding StatusText}"
                     Foreground="{Binding StatusBrush, Converter={StaticResource BrushConv}}"
                     FontSize="11" TextWrapping="Wrap"
                     IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          <ProgressBar IsIndeterminate="True" Height="4" IsVisible="{Binding IsRunning}" />
        </StackPanel>
      </Border>
    </DataTemplate>

    <!-- Status item row -->
    <DataTemplate DataType="{x:Type vm:StatusItemViewModel}">
      <Grid ColumnDefinitions="150,*,Auto" Margin="0 4">
        <TextBlock Grid.Column="0" Text="{Binding Label}" Classes="muted" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" Text="{Binding Value}" Classes="body" TextWrapping="Wrap"
                   Margin="8 0" VerticalAlignment="Center" />
        <Border Grid.Column="2" CornerRadius="9" Padding="8 3" Background="#F4F9FD">
          <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold"
                     Foreground="{Binding Brush, Converter={StaticResource BrushConv}}" />
        </Border>
      </Grid>
    </DataTemplate>

    <!-- Health metric -->
    <DataTemplate DataType="{x:Type vm:HealthMetricViewModel}">
      <Border Classes="card" Width="220" Margin="0 0 12 12" Padding="14">
        <StackPanel Spacing="4">
          <TextBlock Text="{Binding Label}" Classes="muted" />
          <TextBlock Text="{Binding Value}" Classes="h2" TextWrapping="Wrap" />
          <TextBlock Text="{Binding HelperText}" Classes="muted" TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </DataTemplate>

    <!-- Health chip -->
    <DataTemplate DataType="{x:Type vm:HealthStatusChipViewModel}">
      <Border CornerRadius="14" Padding="12 6" Margin="0 0 8 8" Background="White"
              BorderBrush="{StaticResource ZenStrokeBrush}" BorderThickness="1">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="{Binding Label}" Classes="muted" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="Bold"
                     Foreground="{Binding Brush, Converter={StaticResource BrushConv}}" />
        </StackPanel>
      </Border>
    </DataTemplate>

    <!-- Recent activity -->
    <DataTemplate DataType="{x:Type vm:RecentActivityViewModel}">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="0 5">
        <Border Grid.Column="0" CornerRadius="10" Width="30" Height="24" Background="#F0FAF7">
          <TextBlock Text="{Binding Icon}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Foreground="{Binding Brush, Converter={StaticResource BrushConv}}" />
        </Border>
        <StackPanel Grid.Column="1" Margin="10 0">
          <TextBlock Text="{Binding Title}" Classes="body" FontWeight="SemiBold" />
          <TextBlock Text="{Binding TimeText}" Classes="muted" />
        </StackPanel>
        <TextBlock Grid.Column="2" Text="{Binding Duration}" Classes="muted" VerticalAlignment="Center" />
      </Grid>
    </DataTemplate>

    <!-- Log row -->
    <DataTemplate DataType="{x:Type vm:LogRowViewModel}">
      <Grid ColumnDefinitions="170,*,170,90" Margin="0 3">
        <TextBlock Grid.Column="0" Text="{Binding Time}" Classes="muted" />
        <TextBlock Grid.Column="1" Text="{Binding Action}" Classes="body" TextWrapping="Wrap" />
        <TextBlock Grid.Column="2" Text="{Binding Result}" Classes="body" FontWeight="SemiBold" />
        <TextBlock Grid.Column="3" Text="{Binding Duration}" Classes="muted" />
      </Grid>
    </DataTemplate>

    <!-- Category filter chip -->
    <DataTemplate DataType="{x:Type vm:CategoryFilterViewModel}">
      <Button Classes="chip" Classes.selected="{Binding IsSelected}" Margin="0 0 8 8"
              Content="{Binding Name}"
              Command="{Binding $parent[Window].DataContext.SelectWorkflowCategoryCommand}"
              CommandParameter="{Binding}" />
    </DataTemplate>
  </Window.DataTemplates>

  <Panel>
    <Grid ColumnDefinitions="240,*">

      <!-- ======================= Sidebar ======================= -->
      <Border Grid.Column="0" Background="#0B2F38">
        <DockPanel Margin="16">
          <StackPanel DockPanel.Dock="Top" Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="4 8 0 8">
              <Image Source="avares://ZenIT/Assets/logo.png" Width="34" Height="34" />
              <StackPanel>
                <TextBlock Text="ZenIT" Foreground="White" FontSize="19" FontWeight="Bold" />
                <TextBlock Text="{Binding CompanyName}" Foreground="#8FB4BF" FontSize="11" />
              </StackPanel>
            </StackPanel>
            <ItemsControl ItemsSource="{Binding NavigationItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:NavigationItemViewModel}">
                  <Button Classes="nav" Classes.selected="{Binding IsSelected}" Margin="0 2"
                          Command="{Binding $parent[Window].DataContext.SelectNavigationCommand}"
                          CommandParameter="{Binding}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                      <TextBlock Text="{Binding IconText}" FontSize="11" FontWeight="Bold" Width="24" />
                      <TextBlock Text="{Binding Title}" />
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
          <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" Spacing="4">
            <TextBlock Text="{Binding Username}" Foreground="#D7E7EE" FontSize="12" />
            <TextBlock Text="{Binding SidebarVersionText}" Foreground="#5E828D" FontSize="11" />
          </StackPanel>
          <Panel />
        </DockPanel>
      </Border>

      <!-- ======================= Main area ======================= -->
      <DockPanel Grid.Column="1">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="{StaticResource ZenStrokeBrush}"
                BorderThickness="0 0 0 1" Padding="24 16">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Text="{Binding CurrentPageTitle}" Classes="h1" />
              <TextBlock Text="{Binding CurrentPageSubtitle}" Classes="muted" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <Border CornerRadius="12" Padding="10 5" Background="#F0FAF7">
                <TextBlock Text="{Binding ReadyToHelpText}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource ZenSuccessBrush}" />
              </Border>
              <Button Classes="chip" Content="{Binding EnglishText}" ToolTip.Tip="{Binding LanguageTooltip}"
                      Background="{Binding EnglishLanguageBackground, Converter={StaticResource BrushConv}}"
                      Foreground="{Binding EnglishLanguageForeground, Converter={StaticResource BrushConv}}"
                      BorderBrush="{Binding EnglishLanguageBorder, Converter={StaticResource BrushConv}}"
                      Command="{Binding SwitchLanguageCommand}" CommandParameter="en" />
              <Button Classes="chip" Content="{Binding ArabicText}" ToolTip.Tip="{Binding LanguageTooltip}"
                      Background="{Binding ArabicLanguageBackground, Converter={StaticResource BrushConv}}"
                      Foreground="{Binding ArabicLanguageForeground, Converter={StaticResource BrushConv}}"
                      BorderBrush="{Binding ArabicLanguageBorder, Converter={StaticResource BrushConv}}"
                      Command="{Binding SwitchLanguageCommand}" CommandParameter="ar" />
            </StackPanel>
          </Grid>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="{StaticResource ZenStrokeBrush}"
                BorderThickness="0 1 0 0" Padding="24 8">
          <TextBlock Text="{Binding FooterText}" Classes="muted" HorizontalAlignment="Center" />
        </Border>

        <!-- Content -->
        <ScrollViewer Padding="24">
          <Panel>

            <!-- ============ Home / Quick Fixes ============ -->
            <StackPanel IsVisible="{Binding IsWorkflowGridSelected}" Spacing="18">

              <!-- Home hero + side column -->
              <Grid ColumnDefinitions="*,320" IsVisible="{Binding IsHomeSelected}">
                <StackPanel Grid.Column="0" Spacing="18" Margin="0 0 18 0">
                  <Border Classes="card" Background="#0E4B52" BorderThickness="0" Padding="26">
                    <StackPanel Spacing="8">
                      <Border Background="#1A6E70" CornerRadius="10" Padding="10 4" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding HeroBadgeText}" Foreground="#BFEDEA" FontSize="11" FontWeight="SemiBold" />
                      </Border>
                      <TextBlock Text="{Binding HeroTitle}" Foreground="White" FontSize="24" FontWeight="Bold" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding HeroText}" Foreground="#CFE8EA" FontSize="13" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                  <TextBlock Text="{Binding HomeMainActionTitle}" Classes="h2" />
                  <ItemsControl ItemsSource="{Binding HomeActions}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                  </ItemsControl>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="14">
                  <Border Classes="card">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{Binding DeviceStatusTitleText}" Classes="h2" />
                      <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DeviceLabelText}" Classes="muted" Margin="0 3" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DeviceStatus.DeviceName}" Classes="body" Margin="10 3" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding UserLabelText}" Classes="muted" Margin="0 3" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DeviceStatus.CurrentUser}" Classes="body" Margin="10 3" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding InternetLabelText}" Classes="muted" Margin="0 3" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DeviceStatus.InternetStatus}" Classes="body" Margin="10 3" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding LastCheckLabelText}" Classes="muted" Margin="0 3" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastHealthCheckText}" Classes="body" Margin="10 3" />
                      </Grid>
                    </StackPanel>
                  </Border>
                  <Border Classes="card">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{Binding HomeSupportTitle}" Classes="h2" />
                      <TextBlock Text="{Binding SupportStatus}" Classes="muted" TextWrapping="Wrap" />
                      <Button Classes="primary" Content="{Binding OpenITSupportInSlackText}"
                              Command="{Binding ContactITCommand}" HorizontalAlignment="Stretch" />
                    </StackPanel>
                  </Border>
                  <Border Classes="card">
                    <StackPanel Spacing="6">
                      <TextBlock Text="{Binding RecentActivityTitle}" Classes="h2" />
                      <TextBlock Text="{Binding NoRecentActivityText}" Classes="muted"
                                 IsVisible="{Binding !RecentActivity.Count}" />
                      <ItemsControl ItemsSource="{Binding RecentActivity}" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Grid>

              <!-- Quick Fixes -->
              <StackPanel IsVisible="{Binding IsQuickFixesSelected}" Spacing="12">
                <TextBlock Text="{Binding QuickFixQuestion}" Classes="h2" />
                <TextBox Width="360" HorizontalAlignment="Left" Watermark="{Binding LogsSearchTextLabel}"
                         Text="{Binding QuickFixSearchText, Mode=TwoWay}" />
                <ItemsControl ItemsSource="{Binding WorkflowCategories}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
              </StackPanel>

              <ItemsControl ItemsSource="{Binding FilteredActions}" IsVisible="{Binding IsQuickFixesSelected}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
            </StackPanel>

            <!-- ============ Device Health ============ -->
            <StackPanel IsVisible="{Binding IsDeviceHealthSelected}" Spacing="16">
              <Grid ColumnDefinitions="Auto,*">
                <Border Grid.Column="0" Classes="card" Width="240" ToolTip.Tip="{Binding HealthScoreTooltipText}">
                  <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding DeviceHealthScoreText}" Classes="muted" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding DeviceHealthScore}" FontSize="52" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{Binding DeviceHealthScoreBrush, Converter={StaticResource BrushConv}}" />
                    <TextBlock Text="{Binding DeviceHealthScoreStatus}" FontWeight="SemiBold" HorizontalAlignment="Center"
                               Foreground="{Binding DeviceHealthScoreBrush, Converter={StaticResource BrushConv}}" />
                  </StackPanel>
                </Border>
                <StackPanel Grid.Column="1" Margin="16 0 0 0" Spacing="10" VerticalAlignment="Center">
                  <ItemsControl ItemsSource="{Binding HealthStatusChips}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                  </ItemsControl>
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Classes="primary" Content="{Binding RunHealthCheckText}" Command="{Binding RunHealthCheckCommand}" />
                    <Button Classes="secondary" Content="{Binding CreateSupportPackageText}" Command="{Binding CollectITReportCommand}" />
                    <Button Classes="secondary" Content="{Binding OpenReportsFolderText}" Command="{Binding OpenReportsFolderCommand}" />
                  </StackPanel>
                  <TextBlock Text="{Binding HealthCheckStatus}" TextWrapping="Wrap"
                             Foreground="{Binding HealthCheckStatusBrush, Converter={StaticResource BrushConv}}" />
                  <StackPanel Orientation="Horizontal" Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding LastHealthCheckLabelText}" Classes="muted" />
                      <TextBlock Text="{Binding LastHealthCheckText}" Classes="body" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding LastSupportPackageLabelText}" Classes="muted" />
                      <TextBlock Text="{Binding LastSupportPackageText}" Classes="body" />
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
              </Grid>

              <ItemsControl ItemsSource="{Binding HealthMetrics}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>

              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                <Border Grid.Row="0" Grid.Column="0" Classes="card" Margin="0 0 8 12">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding ConnectivityText}" Classes="h2" />
                    <ItemsControl ItemsSource="{Binding ConnectivityHealthItems}" />
                  </StackPanel>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Classes="card" Margin="8 0 0 12">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding SecurityText}" Classes="h2" />
                    <ItemsControl ItemsSource="{Binding SecurityHealthItems}" />
                  </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Classes="card" Margin="0 0 8 0">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding PerformanceText}" Classes="h2" />
                    <ItemsControl ItemsSource="{Binding PerformanceHealthItems}" />
                  </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Classes="card" Margin="8 0 0 0">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding UpdatesText}" Classes="h2" />
                    <ItemsControl ItemsSource="{Binding UpdatesHealthItems}" />
                  </StackPanel>
                </Border>
              </Grid>
            </StackPanel>

            <!-- ============ IT Mode: Unlock ============ -->
            <Grid IsVisible="{Binding IsItModeUnlockVisible}" ColumnDefinitions="*,380">
              <StackPanel Grid.Column="0" Spacing="14" Margin="0 0 18 0">
                <Border Classes="card">
                  <StackPanel Spacing="8">
                    <TextBlock Text="{Binding ITSecureAccessText}" Classes="h1" />
                    <TextBlock Text="{Binding ITUnlockIntroText}" Classes="muted" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ITUnlockHelpText}" Classes="body" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
                <Border Classes="card">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding ITWhatUnlocksText}" Classes="h2" />
                    <WrapPanel>
                      <Border Background="#F0FAF7" CornerRadius="10" Padding="10 5" Margin="0 0 8 8"><TextBlock Text="{Binding ITCapabilityAdvancedRepairsText}" FontSize="12" Foreground="{StaticResource ZenDeepTealBrush}" /></Border>
                      <Border Background="#F0FAF7" CornerRadius="10" Padding="10 5" Margin="0 0 8 8"><TextBlock Text="{Binding ITCapabilityDiagnosticsText}" FontSize="12" Foreground="{StaticResource ZenDeepTealBrush}" /></Border>
                      <Border Background="#F0FAF7" CornerRadius="10" Padding="10 5" Margin="0 0 8 8"><TextBlock Text="{Binding ITCapabilityNetworkToolsText}" FontSize="12" Foreground="{StaticResource ZenDeepTealBrush}" /></Border>
                      <Border Background="#F0FAF7" CornerRadius="10" Padding="10 5" Margin="0 0 8 8"><TextBlock Text="{Binding ITCapabilityMacRepairText}" FontSize="12" Foreground="{StaticResource ZenDeepTealBrush}" /></Border>
                      <Border Background="#F0FAF7" CornerRadius="10" Padding="10 5" Margin="0 0 8 8"><TextBlock Text="{Binding ITCapabilitySecurityChecksText}" FontSize="12" Foreground="{StaticResource ZenDeepTealBrush}" /></Border>
                      <Border Background="#F0FAF7" CornerRadius="10" Padding="10 5" Margin="0 0 8 8"><TextBlock Text="{Binding ITCapabilitySystemLogsText}" FontSize="12" Foreground="{StaticResource ZenDeepTealBrush}" /></Border>
                      <Border Background="#F0FAF7" CornerRadius="10" Padding="10 5" Margin="0 0 8 8"><TextBlock Text="{Binding ITCapabilityReportsText}" FontSize="12" Foreground="{StaticResource ZenDeepTealBrush}" /></Border>
                    </WrapPanel>
                  </StackPanel>
                </Border>
                <Border Classes="card">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding ITSecurityHeadingText}" Classes="h2" />
                    <TextBlock Text="{Binding ITSecurityAdminAuthText}" Classes="body" />
                    <TextBlock Text="{Binding ITSecurityLoggedText}" Classes="body" />
                    <TextBlock Text="{Binding ITSecurityNoPasswordsText}" Classes="body" />
                    <TextBlock Text="{Binding ITSecurityAuditableText}" Classes="body" />
                  </StackPanel>
                </Border>
              </StackPanel>

              <Border Grid.Column="1" Classes="card" VerticalAlignment="Top">
                <StackPanel Spacing="10">
                  <TextBlock Text="{Binding ITAdministratorAccessText}" Classes="h2" />
                  <TextBlock Text="{Binding ITAdministratorAccessSubtitleText}" Classes="muted" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding ITUsernameText}" Classes="muted" />
                  <TextBox Text="{Binding ITModeUsernameAttempt, Mode=TwoWay}" />
                  <TextBlock Text="{Binding ITPasswordText}" Classes="muted" />
                  <TextBox Name="UnlockPasswordBox" PasswordChar="•"
                           RevealPassword="{Binding #ShowUnlockPasswordCheckBox.IsChecked}" />
                  <CheckBox Name="ShowUnlockPasswordCheckBox" Content="{Binding ITShowPasswordText}" />
                  <Button Classes="primary" HorizontalAlignment="Stretch"
                          Content="{Binding ITAuthenticatingButtonText}"
                          Command="{Binding UnlockITModeCommand}" />
                  <TextBlock Text="{Binding ItModeStatus}" TextWrapping="Wrap"
                             Foreground="{Binding ItModeStatusBrush, Converter={StaticResource BrushConv}}" />
                  <TextBlock Text="{Binding ITCredentialsProtectedText}" Classes="muted" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding ITNeedAccessText}" Classes="muted" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </Grid>

            <!-- ============ IT Mode: Dashboard ============ -->
            <StackPanel IsVisible="{Binding IsItModeDashboardVisible}" Spacing="16">
              <Border Classes="card" Background="#F0FAF7">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="3">
                    <TextBlock Text="{Binding ITUnlockedText}" Classes="h2" />
                    <TextBlock Text="{Binding SignedInITUserText}" Classes="muted" />
                    <TextBlock Text="{Binding ITUnlockedBodyText}" Classes="muted" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ITWorkflowNoticeText}" Classes="muted" TextWrapping="Wrap" />
                  </StackPanel>
                  <Button Grid.Column="1" Classes="secondary" VerticalAlignment="Top"
                          Content="{Binding LockITModeText}" Command="{Binding LockITModeCommand}" />
                </Grid>
              </Border>

              <Border Classes="card">
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding ITSummaryText}" Classes="h2" />
                  <ItemsControl ItemsSource="{Binding ItSummaryItems}" />
                </StackPanel>
              </Border>

              <Grid ColumnDefinitions="*,*">
                <Border Grid.Column="0" Classes="card" Margin="0 0 8 0">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding ITNetworkText}" Classes="h2" />
                    <TextBlock Text="{Binding ITNetworkDescriptionText}" Classes="muted" TextWrapping="Wrap" />
                    <ItemsControl ItemsSource="{Binding ItNetworkDiagnostics}" />
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="card" Margin="8 0 0 0">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding ITSystemText}" Classes="h2" />
                    <TextBlock Text="{Binding ITSystemDescriptionText}" Classes="muted" TextWrapping="Wrap" />
                    <ItemsControl ItemsSource="{Binding ItSystemDiagnostics}" />
                  </StackPanel>
                </Border>
              </Grid>

              <Border Classes="card">
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding ITZenHREnvironmentText}" Classes="h2" />
                  <TextBlock Text="{Binding ITZenHREnvironmentDescriptionText}" Classes="muted" TextWrapping="Wrap" />
                  <ItemsControl ItemsSource="{Binding ItEnvironmentDiagnostics}" />
                </StackPanel>
              </Border>

              <StackPanel Spacing="10">
                <TextBlock Text="{Binding ITAdvancedRepairsText}" Classes="h2" />
                <ItemsControl ItemsSource="{Binding ITWorkflowCategories}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:CategoryFilterViewModel}">
                      <Button Classes="chip" Classes.selected="{Binding IsSelected}" Margin="0 0 8 8"
                              Content="{Binding Name}"
                              Command="{Binding $parent[Window].DataContext.SelectITWorkflowCategoryCommand}"
                              CommandParameter="{Binding}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding FilteredITActions}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
              </StackPanel>

              <Border Classes="card">
                <StackPanel Spacing="8">
                  <TextBlock Text="{Binding ITLogsText}" Classes="h2" />
                  <TextBlock Text="{Binding LogsIntroText}" Classes="muted" TextWrapping="Wrap" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox Width="240" Watermark="{Binding LogsSearchTextLabel}"
                             Text="{Binding LogsSearchText, Mode=TwoWay}" />
                    <ItemsControl ItemsSource="{Binding LogFilters}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:CategoryFilterViewModel}">
                          <Button Classes="chip" Classes.selected="{Binding IsSelected}" Margin="0 0 8 0"
                                  Content="{Binding Name}"
                                  Command="{Binding $parent[Window].DataContext.SelectLogFilterCommand}"
                                  CommandParameter="{Binding}" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding LogSortOptions}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:CategoryFilterViewModel}">
                          <Button Classes="chip" Classes.selected="{Binding IsSelected}" Margin="0 0 8 0"
                                  Content="{Binding Name}"
                                  Command="{Binding $parent[Window].DataContext.SelectLogSortCommand}"
                                  CommandParameter="{Binding}" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                  <Grid ColumnDefinitions="170,*,170,90">
                    <TextBlock Grid.Column="0" Text="{Binding LogsTimeText}" Classes="muted" FontWeight="Bold" />
                    <TextBlock Grid.Column="1" Text="{Binding LogsWorkflowText}" Classes="muted" FontWeight="Bold" />
                    <TextBlock Grid.Column="2" Text="{Binding LogsResultText}" Classes="muted" FontWeight="Bold" />
                    <TextBlock Grid.Column="3" Text="{Binding LogsDurationText}" Classes="muted" FontWeight="Bold" />
                  </Grid>
                  <ItemsControl ItemsSource="{Binding FilteredLogRows}" MaxHeight="360" />
                  <TextBlock Text="{Binding LogsStatus}" Classes="muted" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding FallbackLogPathText}" Classes="muted" IsVisible="{Binding IsFallbackLogVisible}" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Classes="secondary" Content="{Binding RefreshText}" Command="{Binding RefreshLogsCommand}" />
                    <Button Classes="secondary" Content="{Binding OpenLogFolderText}" Command="{Binding OpenLogFolderCommand}" />
                    <Button Classes="secondary" Content="{Binding CopyLatestSummaryText}" Command="{Binding CopyLatestSummaryCommand}" />
                    <Button Classes="secondary" Content="{Binding ExportLogText}" Command="{Binding ExportLogCommand}" />
                    <Button Classes="secondary" Content="{Binding OpenReportsFolderText}" Command="{Binding OpenReportsFolderCommand}" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Classes="card">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding ITReportsText}" Classes="h2" />
                  <TextBlock Text="{Binding ITReportsDescriptionText}" Classes="muted" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding ITCredentialsManagedText}" Classes="muted" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding ITCredentialChangesDisabledText}" Classes="muted" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>

            <!-- ============ About ============ -->
            <StackPanel IsVisible="{Binding IsAboutSelected}" Spacing="16" MaxWidth="880" HorizontalAlignment="Left">
              <Border Classes="card">
                <StackPanel Spacing="8">
                  <StackPanel Orientation="Horizontal" Spacing="12">
                    <Image Source="avares://ZenIT/Assets/logo-display.png" Width="56" Height="56" />
                    <StackPanel>
                      <TextBlock Text="{Binding AboutTitleText}" Classes="h1" />
                      <TextBlock Text="{Binding AboutSubtitleText}" Classes="muted" />
                    </StackPanel>
                  </StackPanel>
                  <TextBlock Text="{Binding AboutBodyText}" Classes="body" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <Border Classes="card">
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding AboutOwnerText}" Classes="muted" Margin="0 3" />
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CompanyName}" Classes="body" Margin="14 3" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding AboutVersionText}" Classes="muted" Margin="0 3" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AppVersion}" Classes="body" Margin="14 3" />
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding AboutBuildDateText}" Classes="muted" Margin="0 3" />
                  <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding BuildDate}" Classes="body" Margin="14 3" />
                  <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding AboutRuntimeText}" Classes="muted" Margin="0 3" />
                  <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RuntimeInfo}" Classes="body" Margin="14 3" />
                  <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding AboutConfigurationModeText}" Classes="muted" Margin="0 3" />
                  <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ConfigurationMode}" Classes="body" Margin="14 3" />
                  <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding AboutUpdateChannelText}" Classes="muted" Margin="0 3" />
                  <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding UpdateChannel}" Classes="body" Margin="14 3" />
                </Grid>
              </Border>
              <Border Classes="card">
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding AboutPrivacyTitleText}" Classes="h2" />
                  <TextBlock Text="{Binding AboutPrivacyText}" Classes="body" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding AboutPrivacyNeverCollectsText}" Classes="muted" FontWeight="SemiBold" />
                  <WrapPanel>
                    <Border Background="#F4F9FD" CornerRadius="10" Padding="10 5" Margin="0 0 8 8"><TextBlock Text="{Binding AboutPasswordsText}" FontSize="12" /></Border>
                    <Border Background="#F4F9FD" CornerRadius="10" Padding="10 5" Margin="0 0 8 8"><TextBlock Text="{Binding AboutCookiesText}" FontSize="12" /></Border>
                    <Border Background="#F4F9FD" CornerRadius="10" Padding="10 5" Margin="0 0 8 8"><TextBlock Text="{Binding AboutBrowserHistoryText}" FontSize="12" /></Border>
                    <Border Background="#F4F9FD" CornerRadius="10" Padding="10 5" Margin="0 0 8 8"><TextBlock Text="{Binding AboutEmailsText}" FontSize="12" /></Border>
                    <Border Background="#F4F9FD" CornerRadius="10" Padding="10 5" Margin="0 0 8 8"><TextBlock Text="{Binding AboutPersonalFilesText}" FontSize="12" /></Border>
                  </WrapPanel>
                </StackPanel>
              </Border>
              <Border Classes="card">
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding AboutSecurityTitleText}" Classes="h2" />
                  <TextBlock Text="{Binding AboutITModeProtectedText}" Classes="body" />
                  <TextBlock Text="{Binding AboutLocalExecutionOnlyText}" Classes="body" />
                  <TextBlock Text="{Binding AboutSupportPackagesExcludePersonalDataText}" Classes="body" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Panel>
        </ScrollViewer>
      </DockPanel>
    </Grid>

    <!-- ============ Confirmation overlay ============ -->
    <Panel IsVisible="{Binding IsConfirmationVisible}" Background="#88172B3A">
      <Border Classes="card" Width="440" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24">
        <StackPanel Spacing="10">
          <TextBlock Text="{Binding ConfirmITWorkflowText}" Classes="h2" />
          <TextBlock Text="{Binding ConfirmationWorkflowName}" Classes="h1" />
          <TextBlock Text="{Binding ConfirmationDescription}" Classes="body" TextWrapping="Wrap" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{Binding RiskLevelText}" Classes="muted" />
            <TextBlock Text="{Binding ConfirmationRiskLevel}" Classes="body" FontWeight="Bold" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{Binding PermissionsText}" Classes="muted" />
            <TextBlock Text="{Binding ConfirmationAdminText}" Classes="body" />
          </StackPanel>
          <TextBlock Text="{Binding LoggedNoticeText}" Classes="muted" TextWrapping="Wrap" />
          <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <Button Classes="secondary" Content="{Binding CancelText}" Command="{Binding CancelRunCommand}" />
            <Button Classes="primary" Content="{Binding ConfirmationContinueText}" Command="{Binding ConfirmRunCommand}" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Panel>

    <!-- ============ Toast ============ -->
    <Border IsVisible="{Binding IsToastVisible}" HorizontalAlignment="Center" VerticalAlignment="Bottom"
            Margin="0 0 0 28" CornerRadius="12" Padding="16 10" MaxWidth="560"
            Background="{Binding ToastBrush, Converter={StaticResource BrushConv}}">
      <TextBlock Text="{Binding ToastMessage}" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap" />
    </Border>
  </Panel>
</Window>
