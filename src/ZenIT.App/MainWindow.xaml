                                                    MinHeight="190"
                                                    Margin="0,0,16,16"
                                                    Padding="18">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="48" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="42" Height="42" CornerRadius="14" Background="#FFF9EE" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1">
                                                            <TextBlock Text="{Binding IconText}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource ZenTealDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource ZenNavyBrush}" TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding Category}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ZenMutedBrush}" Margin="0,4,0,0" />
                                                        </StackPanel>
                                                        <Border Grid.Column="2" Padding="8,4" CornerRadius="12" Background="#FFF9EE" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1">
                                                            <TextBlock Text="{Binding BadgeText}" FontSize="10" FontWeight="Bold" Foreground="{Binding CardBorderBrush}" />
                                                        </Border>
                                                    </Grid>
                                                    <StackPanel Grid.Row="1" Margin="0,12,0,12">
                                                        <TextBlock Text="{Binding Description}" Foreground="{StaticResource ZenMutedBrush}" FontSize="13" LineHeight="18" TextWrapping="Wrap" />
                                                        <Border Background="#F7FBFE" BorderBrush="#E3EFF7" BorderThickness="1" CornerRadius="14" Padding="12" Height="82" Margin="0,10,0,0">
                                                            <Grid>
                                                                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}" FontSize="12.5" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                                <TextBlock Text="{Binding DataContext.RunningText, RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Foreground="{StaticResource ZenMutedBrush}" FontSize="11" Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                            </Grid>
                                                        </Border>
                                                    </StackPanel>
                                                    <Button Grid.Row="2" Content="{Binding ButtonText}" Command="{Binding RunCommand}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>

