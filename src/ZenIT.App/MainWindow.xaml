                                                       Foreground="{StaticResource ZenMutedBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Margin="0,12,0,0" />
                                            <TextBlock Text="{Binding ITNeedAccessText}"
                                                       Foreground="{StaticResource ZenTealDarkBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       Margin="0,8,0,0" />
                                            <Button Content="{Binding ITAuthenticatingButtonText}"
                                                    Command="{Binding UnlockITModeCommand}"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    HorizontalAlignment="Stretch"
                                                    MinHeight="46"
                                                    Margin="0,20,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Grid Margin="0,30,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Background="#F7FBFE"
                                            BorderBrush="{StaticResource ZenStrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="20"
                                            Padding="22">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ITWhatUnlocksText}"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource ZenNavyBrush}"
                                                       Margin="0,0,0,14" />
                                            <UniformGrid Columns="2">
                                                <TextBlock FontWeight="SemiBold" Margin="0,5"><Run Text="✓ " /><Run Text="{Binding ITCapabilityAdvancedRepairsText, Mode=OneWay}" /></TextBlock>
                                                <TextBlock FontWeight="SemiBold" Margin="0,5"><Run Text="✓ " /><Run Text="{Binding ITCapabilityDiagnosticsText, Mode=OneWay}" /></TextBlock>
                                                <TextBlock FontWeight="SemiBold" Margin="0,5"><Run Text="✓ " /><Run Text="{Binding ITCapabilityNetworkToolsText, Mode=OneWay}" /></TextBlock>
                                                <TextBlock FontWeight="SemiBold" Margin="0,5"><Run Text="✓ " /><Run Text="{Binding ITCapabilityWindowsRepairText, Mode=OneWay}" /></TextBlock>
                                                <TextBlock FontWeight="SemiBold" Margin="0,5"><Run Text="✓ " /><Run Text="{Binding ITCapabilitySecurityChecksText, Mode=OneWay}" /></TextBlock>
                                                <TextBlock FontWeight="SemiBold" Margin="0,5"><Run Text="✓ " /><Run Text="{Binding ITCapabilitySystemLogsText, Mode=OneWay}" /></TextBlock>
                                                <TextBlock FontWeight="SemiBold" Margin="0,5"><Run Text="✓ " /><Run Text="{Binding ITCapabilityReportsText, Mode=OneWay}" /></TextBlock>
                                                <TextBlock FontWeight="SemiBold" Margin="0,5"><Run Text="✓ " /><Run Text="{Binding ITCapabilityDeploymentToolsText, Mode=OneWay}" /></TextBlock>
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Background="#F7FBFE"
                                            BorderBrush="{StaticResource ZenStrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="20"
                                            Padding="22">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ITSecurityHeadingText}"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource ZenNavyBrush}"
                                                       Margin="0,0,0,14" />
                                            <TextBlock Margin="0,5" TextWrapping="Wrap"><Run Text="• " /><Run Text="{Binding ITSecurityAdminAuthText, Mode=OneWay}" /></TextBlock>
                                            <TextBlock Margin="0,5" TextWrapping="Wrap"><Run Text="• " /><Run Text="{Binding ITSecurityLoggedText, Mode=OneWay}" /></TextBlock>
                                            <TextBlock Margin="0,5" TextWrapping="Wrap"><Run Text="• " /><Run Text="{Binding ITSecurityNoPasswordsText, Mode=OneWay}" /></TextBlock>
                                            <TextBlock Margin="0,5" TextWrapping="Wrap"><Run Text="• " /><Run Text="{Binding ITSecurityAuditableText, Mode=OneWay}" /></TextBlock>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1"
                          Visibility="{Binding IsItModeDashboardVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                          Margin="0,24,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardStyle}" Padding="28">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Background="#E8F8F4"
                                                BorderBrush="#BFEFDF"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                Padding="10,5">
                                            <TextBlock Text="{Binding ITAdministratorVerifiedText}"
                                                       Foreground="{StaticResource ZenSuccessBrush}"
                                                       FontWeight="Bold"
                                                       FontSize="12" />
                                        </Border>
                                        <TextBlock Text="{Binding SignedInITUserText}"
                                                   Foreground="{StaticResource ZenMutedBrush}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding ITUnlockedText}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource ZenNavyBrush}" />
                                    <TextBlock Text="{Binding ITUnlockedBodyText}"
                                               FontSize="14"
                                               Foreground="{StaticResource ZenMutedBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,7,0,0" />
                                    <TextBlock Text="{Binding ItModeStatus}"
                                               Foreground="{Binding ItModeStatusBrush}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Margin="0,12,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="{Binding LockITModeText}"
                                        Command="{Binding LockITModeCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        VerticalAlignment="Center"
                                        Margin="24,0,0,0" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="22" Margin="0,22,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding ITSummaryText}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ZenNavyBrush}" />
                                <ItemsControl ItemsSource="{Binding ItSummaryItems}" Margin="0,14,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="210" MinHeight="72" Background="#F7FBFE" BorderBrush="{StaticResource ZenStrokeBrush}" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,0,12,12">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource ZenMutedBrush}" FontSize="11" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Value}" Foreground="{StaticResource ZenNavyBrush}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,0,16,16">
                                <StackPanel>
                                    <TextBlock Text="{Binding ITNetworkText}"
                                               FontSize="19"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource ZenNavyBrush}" />
                                    <TextBlock Text="{Binding ITNetworkDescriptionText}"
                                               Foreground="{StaticResource ZenMutedBrush}"
                                               FontSize="13.5"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,12" />
                                    <ItemsControl ItemsSource="{Binding ItNetworkDiagnostics}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid MinHeight="34">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                    <StackPanel><TextBlock Text="{Binding Label}" FontWeight="SemiBold" Foreground="{StaticResource ZenNavyBrush}" /><TextBlock Text="{Binding Value}" FontSize="12" Foreground="{StaticResource ZenMutedBrush}" /></StackPanel>
                                                    <Border Grid.Column="1" CornerRadius="12" Padding="9,4" Background="#F7FCFF" BorderBrush="{Binding Brush}" BorderThickness="1"><TextBlock Text="{Binding Status}" Foreground="{Binding Brush}" FontSize="11" FontWeight="Bold" /></Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="22" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{Binding ITSystemText}"
                                               FontSize="19"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource ZenNavyBrush}" />
                                    <TextBlock Text="{Binding ITSystemDescriptionText}"
                                               Foreground="{StaticResource ZenMutedBrush}"
                                               FontSize="13.5"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,12" />
                                    <ItemsControl ItemsSource="{Binding ItSystemDiagnostics}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid MinHeight="34">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                    <StackPanel><TextBlock Text="{Binding Label}" FontWeight="SemiBold" Foreground="{StaticResource ZenNavyBrush}" /><TextBlock Text="{Binding Value}" FontSize="12" Foreground="{StaticResource ZenMutedBrush}" /></StackPanel>
                                                    <Border Grid.Column="1" CornerRadius="12" Padding="9,4" Background="#F7FCFF" BorderBrush="{Binding Brush}" BorderThickness="1"><TextBlock Text="{Binding Status}" Foreground="{Binding Brush}" FontSize="11" FontWeight="Bold" /></Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="22" Margin="0,0,16,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding ITZenHREnvironmentText}"
                                               FontSize="19"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource ZenNavyBrush}" />
                                    <TextBlock Text="{Binding ITZenHREnvironmentDescriptionText}"
                                               Foreground="{StaticResource ZenMutedBrush}"
                                               FontSize="13.5"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,12" />
                                    <ItemsControl ItemsSource="{Binding ItEnvironmentDiagnostics}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid MinHeight="34">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                    <StackPanel><TextBlock Text="{Binding Label}" FontWeight="SemiBold" Foreground="{StaticResource ZenNavyBrush}" /><TextBlock Text="{Binding Value}" FontSize="12" Foreground="{StaticResource ZenMutedBrush}" /></StackPanel>
                                                    <Border Grid.Column="1" CornerRadius="12" Padding="9,4" Background="#F7FCFF" BorderBrush="{Binding Brush}" BorderThickness="1"><TextBlock Text="{Binding Status}" Foreground="{Binding Brush}" FontSize="11" FontWeight="Bold" /></Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}" Padding="22">
                                <StackPanel>
                                    <TextBlock Text="{Binding ITAdminToolsText}"
                                               FontSize="19"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource ZenNavyBrush}" />
                                    <TextBlock Text="{Binding ITCredentialsManagedText}"
                                               Foreground="{StaticResource ZenMutedBrush}"
                                               FontSize="13.5"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,12" />
                                    <Border Background="#F7FBFE"
                                            BorderBrush="{StaticResource ZenStrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Padding="16"
                                            Margin="0,4,0,0">
                                        <TextBlock Text="{Binding ITCredentialChangesDisabledText}"
                                                   Foreground="{StaticResource ZenTealDarkBrush}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="24" Margin="0,22,0,0">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ITLogsText}"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource ZenNavyBrush}" />
                                        <TextBlock Text="{Binding LogsStatus}"
                                                   Foreground="{StaticResource ZenMutedBrush}"
                                                   FontSize="13.5"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="{Binding RefreshText}"
                                                Command="{Binding RefreshLogsCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Margin="0,0,8,0" />
                                        <Button Content="{Binding OpenLogFolderText}"
                                                Command="{Binding OpenLogFolderCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,16,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid Background="#F8FCFF" Height="42">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="110" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding LogsTimeText}" FontWeight="Bold" Foreground="{StaticResource ZenMutedBrush}" Margin="18,0,0,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding LogsWorkflowText}" FontWeight="Bold" Foreground="{StaticResource ZenMutedBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding LogsResultText}" FontWeight="Bold" Foreground="{StaticResource ZenMutedBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding LogsDurationText}" FontWeight="Bold" Foreground="{StaticResource ZenMutedBrush}" VerticalAlignment="Center" />
                                    </Grid>
                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding FilteredLogRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid MinHeight="38">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="170" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="110" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Time}" Foreground="{StaticResource ZenMutedBrush}" Margin="18,0,0,0" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Action}" Foreground="{StaticResource ZenNavyBrush}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Result}" Foreground="{StaticResource ZenTealDarkBrush}" FontWeight="Bold" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="3" Text="{Binding Duration}" Foreground="{StaticResource ZenMutedBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="24" Margin="0,22,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding ITReportsText}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource ZenNavyBrush}" />
                                    <TextBlock Text="{Binding ITReportsDescriptionText}"
                                               Foreground="{StaticResource ZenMutedBrush}"
                                               FontSize="13.5"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="{Binding OpenReportsFolderText}"
                                        Command="{Binding OpenReportsFolderCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        VerticalAlignment="Center"
                                        Margin="24,0,0,0" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="5" Style="{StaticResource CardStyle}" Padding="24" Margin="0,22,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding ITAdvancedRepairsText}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ZenNavyBrush}" />
                                <TextBlock Text="{Binding ITWorkflowNoticeText}"
                                           Foreground="{StaticResource ZenMutedBrush}"
                                           FontSize="13.5"
                                           TextWrapping="Wrap"
                                           Margin="0,7,0,16" />
                                <ItemsControl ItemsSource="{Binding ITWorkflowCategories}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Name}"
                                                    Command="{Binding DataContext.SelectITWorkflowCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    MinWidth="118"
                                                    Margin="0,0,10,10" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl ItemsSource="{Binding FilteredITActions}" Margin="0,12,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel HorizontalAlignment="Left" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardStyle}"
                                                    Background="{Binding CardBackground}"
                                                    BorderBrush="{Binding CardBorderBrush}"
