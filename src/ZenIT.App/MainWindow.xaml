<Window x:Class="ZenIT.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ZenIT.App.ViewModels"
        Title="ZenIT | Self-Service IT Assistant"
        Width="1280"
        Height="790"
        MinWidth="900"
        MinHeight="680"
        Icon="Assets/ZenIT.ico"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen"
        FlowDirection="{Binding AppFlowDirection}"
        FontFamily="Segoe UI, Segoe UI Arabic"
        Background="#EEF6FF">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ZenCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ZenStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Effect" Value="{StaticResource CardShadow}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect" Value="{StaticResource CardHoverShadow}" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.004" ScaleY="1.004" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="#DDEDF3" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="15"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1BFFFFFF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#24FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.99" ScaleY="0.99" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#80FFFFFF" />
                                <Setter TargetName="Root" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LanguageSegmentButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Effect" Value="{StaticResource ButtonShadow}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource ZenTealBrush}" />
                                <Setter TargetName="Root" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#172B3A" Offset="0" />
                    <GradientStop Color="#006D73" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Image Source="Assets/logo-display.png"
                           Width="104"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"
                           AutomationProperties.Name="ZenIT logo" />
                    <TextBlock Text="ZenIT"
                               Foreground="White"
                               FontSize="27"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Margin="0,18,0,2" />
                    <TextBlock Text="{Binding AboutSubtitleText}"
                               Foreground="#BFD7DD"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextAlignment="Center" />
                </StackPanel>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding NavigationItems}"
                              Margin="0,52,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectNavigationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#30FFFFFF" />
                                                <Setter Property="BorderBrush" Value="#3FFFFFFF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="26"
                                            Height="26"
                                            CornerRadius="10"
                                            Background="#24FFFFFF"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding IconText}"
                                                   Foreground="White"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               Foreground="White"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Grid.Row="2"
                           Text="{Binding SidebarVersionText}"
                           Foreground="#8FB7C0"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Opacity="0.82"
                           Margin="0,18,0,8" />
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#EEF6FF" Offset="0" />
                    <GradientStop Color="#F7FCFF" Offset="0.46" />
                    <GradientStop Color="#DFF8F7" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid MaxWidth="1180" Margin="32,26,32,26" HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding CurrentPageTitle}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ZenNavyBrush}" />
                            <TextBlock Text="{Binding CurrentPageSubtitle}"
                                       FontSize="14"
                                       Foreground="{StaticResource ZenMutedBrush}"
                                       Margin="0,5,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Padding="6"
                                    Background="#FFFFFF"
                                    BorderBrush="{StaticResource ZenStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="22"
                                    Margin="0,0,10,0"
                                    ToolTip="{Binding LanguageTooltip}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🌐"
                                               FontSize="14"
                                               Margin="6,0,8,0"
                                               VerticalAlignment="Center"
                                               AutomationProperties.Name="{Binding LanguageTooltip}" />
                                    <Button Content="{Binding EnglishText}"
                                            Command="{Binding SwitchLanguageCommand}"
                                            CommandParameter="en"
                                            Style="{StaticResource LanguageSegmentButtonStyle}"
                                            Background="{Binding EnglishLanguageBackground}"
                                            Foreground="{Binding EnglishLanguageForeground}"
                                            BorderBrush="{Binding EnglishLanguageBorder}"
                                            MinWidth="44"
                                            Margin="0,0,5,0" />
                                    <Button Content="{Binding ArabicText}"
                                            Command="{Binding SwitchLanguageCommand}"
                                            CommandParameter="ar"
                                            Style="{StaticResource LanguageSegmentButtonStyle}"
                                            Background="{Binding ArabicLanguageBackground}"
                                            Foreground="{Binding ArabicLanguageForeground}"
                                            BorderBrush="{Binding ArabicLanguageBorder}"
                                            MinWidth="44" />
                                </StackPanel>
                            </Border>
                            <Border Padding="12,6"
                                    Background="#E7FBFA"
                                    BorderBrush="#BEEDEA"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Margin="0,0,10,0">
                                <TextBlock Text="{Binding VersionBadgeText}"
                                           Foreground="{StaticResource ZenTealDarkBrush}"
                                           FontSize="12"
                                           FontWeight="Bold" />
                            </Border>
                            <Border Padding="12,6"
                                    Background="#FFF9EE"
                                    BorderBrush="#F8D99D"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Margin="0,0,10,0"
                                    Visibility="{Binding IsTestMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding AboutTestDiagnosticsText}"
                                           Foreground="{StaticResource ZenWarningBrush}"
                                           FontSize="12"
                                           FontWeight="Bold" />
                            </Border>
                            <Border Padding="16,9"
                                    Background="#FFFFFF"
                                    BorderBrush="{StaticResource ZenStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="9" Height="9" Fill="{StaticResource ZenSuccessBrush}" Margin="0,0,9,0" />
                                        <TextBlock Text="{Binding ReadyToHelpText}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Foreground="{StaticResource ZenTealDarkBrush}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1"
                          Visibility="{Binding IsHomeSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                          Margin="0,24,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardStyle}" Padding="28" MinHeight="204">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="0" />
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center" Margin="0,0,28,0">
                                    <Border Padding="12,6"
                                            Background="#E7FBFA"
                                            BorderBrush="#BEEDEA"
                                            BorderThickness="1"
                                            CornerRadius="15"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding HeroBadgeText}"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource ZenTealDarkBrush}" />
                                    </Border>
                                    <TextBlock Text="{Binding HeroTitle}"
                                               FontSize="34"
                                               FontWeight="Bold"
                                               LineHeight="40"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource ZenNavyBrush}"
                                               Margin="0,14,0,0" />
                                    <TextBlock Text="{Binding HeroText}"
                                               FontSize="14.5"
                                               LineHeight="21"
                                               Foreground="{StaticResource ZenMutedBrush}"
                                               TextWrapping="Wrap"
                                               MaxWidth="590"
                                               Margin="0,12,0,0" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Background="#F8FCFF"
                                        BorderBrush="{StaticResource ZenStrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="20"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding DeviceStatusTitleText}"
                                                   FontSize="17"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,15" />

                                        <UniformGrid Grid.Row="1" Columns="2">
                                            <StackPanel Margin="0,0,18,14">
                                                <TextBlock Text="{Binding DeviceLabelText}" Foreground="{StaticResource ZenMutedBrush}" FontSize="11" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding DeviceStatus.DeviceName}" FontWeight="SemiBold" FontSize="14" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,14">
                                                <TextBlock Text="{Binding UserLabelText}" Foreground="{StaticResource ZenMutedBrush}" FontSize="11" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding DeviceStatus.CurrentUser}" FontWeight="SemiBold" FontSize="14" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,18,0">
                                                <TextBlock Text="{Binding InternetLabelText}" Foreground="{StaticResource ZenMutedBrush}" FontSize="11" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding DeviceStatus.InternetStatus}" FontWeight="SemiBold" FontSize="14" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="{Binding LastCheckLabelText}" Foreground="{StaticResource ZenMutedBrush}" FontSize="11" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding DeviceStatus.LastCheckTime, StringFormat={}{0:h:mm tt}}"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>
                                        </UniformGrid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <UniformGrid Grid.Row="1" Columns="4" Margin="0,22,0,0" Visibility="Collapsed">
                            <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,14,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding LastHealthCheckLabelText}" Foreground="{StaticResource ZenMutedBrush}" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding LastHealthCheckText}" Foreground="{StaticResource ZenNavyBrush}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,14,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding LastSupportPackageLabelText}" Foreground="{StaticResource ZenMutedBrush}" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding LastSupportPackageText}" Foreground="{StaticResource ZenNavyBrush}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" Margin="0,8,0,0" />
                                    <Button Content="{Binding OpenReportsFolderText}"
                                            Command="{Binding OpenReportsFolderCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            HorizontalAlignment="Left"
                                            Margin="0,12,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,14,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding QuickSupportLabelText}" Foreground="{StaticResource ZenMutedBrush}" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding OpenITSupportInSlackText}" Foreground="{StaticResource ZenTealDarkBrush}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" Margin="0,8,0,0" />
                                    <Button Content="{Binding ContactITText}"
                                            Command="{Binding ContactITCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            HorizontalAlignment="Left"
                                            Margin="0,12,0,0" />
                                    <TextBlock Text="{Binding SupportStatus}" Foreground="{StaticResource ZenMutedBrush}" FontSize="11.5" TextWrapping="Wrap" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Padding="18">
                                <StackPanel>
                                    <TextBlock Text="{Binding StatusLabelText}" Foreground="{StaticResource ZenMutedBrush}" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ReadyToHelpText}" Foreground="{StaticResource ZenSuccessBrush}" FontSize="18" FontWeight="Bold" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <TextBlock Grid.Row="2"
                                   Text="{Binding QuickActionsTitle}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ZenNavyBrush}"
                                   Margin="0,24,0,12" />

                        <ItemsControl Grid.Row="3" ItemsSource="{Binding HomeActions}" Margin="0,0,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardStyle}"
                                            Background="{Binding CardBackground}"
                                            BorderBrush="{Binding CardBorderBrush}"
                                            Width="330"
                                            MinHeight="176"
                                            Margin="0,0,16,16"
                                            Padding="18">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="42"
                                                        Height="42"
                                                        CornerRadius="14"
                                                        Background="#E7FBFA"
                                                        BorderBrush="#BEEDEA"
                                                        BorderThickness="1"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding IconText}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource ZenTealDarkBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="17"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource ZenNavyBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Description}"
                                                              TextWrapping="Wrap"
                                                               FontSize="12.5"
                                                               LineHeight="17"
                                                               Foreground="{StaticResource ZenMutedBrush}"
                                                               Margin="0,5,0,0" />
                                                </StackPanel>
                                                <Border Grid.Column="2"
                                                        Background="#E7FBFA"
                                                        BorderBrush="#BEEDEA"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="9,4"
                                                        VerticalAlignment="Top"
                                                        Visibility="{Binding HasBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding BadgeText}"
                                                               Foreground="{StaticResource ZenTealDarkBrush}"
                                                               FontSize="10"
                                                               FontWeight="Bold" />
                                                </Border>
                                            </Grid>

                                            <Border Grid.Row="1"
                                                    Background="#F7FBFE"
                                                    BorderBrush="#E3EFF7"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    Padding="12"
                                                    Height="82"
                                                    Margin="0,13,0,12">
                                                <Grid>
                                                    <TextBlock Text="{Binding StatusText}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{Binding StatusBrush}"
                                                               FontSize="12.5"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding DataContext.RunningText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Bottom"
                                                               Foreground="{StaticResource ZenMutedBrush}"
                                                               FontSize="11"
                                                               Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </Grid>
                                            </Border>

                                            <Button Grid.Row="2"
                                                    Content="{Binding ButtonText}"
                                                    Command="{Binding RunCommand}"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    HorizontalAlignment="Left"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="22" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding RecentActivityTitle}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ZenNavyBrush}" />
                                <ItemsControl ItemsSource="{Binding RecentActivity}" Margin="0,14,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Width="255" MinHeight="54" Margin="0,0,18,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="22" Height="22" CornerRadius="11" Background="{Binding Brush}" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Icon}" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="{StaticResource ZenNavyBrush}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding TimeText}" Foreground="{StaticResource ZenMutedBrush}" FontSize="12" />
                                                    <TextBlock Text="{Binding Duration}" Foreground="{StaticResource ZenMutedBrush}" FontSize="11" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Row="5"
                                   Text="{Binding SupportFooterText}"
                                   Foreground="{StaticResource ZenMutedBrush}"
                                   FontSize="12.5"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4" />
                    </Grid>

                    <Grid Grid.Row="1"
                          Visibility="{Binding IsQuickFixesSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                          Margin="0,24,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardStyle}" Padding="24">
                            <StackPanel>
                                <TextBlock Text="{Binding QuickFixQuestion}"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ZenNavyBrush}" />
                                <TextBox Text="{Binding QuickFixSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Height="44"
                                         FontSize="15"
                                         Padding="14,10"
                                         Margin="0,16,0,14"
                                         BorderBrush="{StaticResource ZenStrokeBrush}"
                                         BorderThickness="1" />
                                <ItemsControl ItemsSource="{Binding WorkflowCategories}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
