                            <UniformGrid Columns="1" Margin="0,34,0,0" MaxWidth="260" HorizontalAlignment="Center">
                                <Border Background="#FFFFFF" BorderBrush="{StaticResource ZenStrokeBrush}" BorderThickness="1" CornerRadius="18" Padding="18" Margin="0,0,0,14" Effect="{StaticResource CardShadow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding AboutVersionText}" Foreground="{StaticResource ZenMutedBrush}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding AppVersion}" FontSize="22" FontWeight="Bold" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <UniformGrid Columns="2" Margin="0,6,0,0">
                                <Border Background="#FFFFFF" BorderBrush="{StaticResource ZenStrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="22" Margin="0,0,16,16" Effect="{StaticResource CardShadow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding AboutPrivacyTitleText}" FontSize="20" FontWeight="Bold" />
                                        <TextBlock Text="{Binding AboutPrivacyNeverCollectsText}" Foreground="{StaticResource ZenMutedBrush}" FontWeight="SemiBold" Margin="0,12,0,8" />
                                        <TextBlock FontWeight="SemiBold" Margin="0,5,0,0"><Run Text="✓ " /><Run Text="{Binding AboutPasswordsText, Mode=OneWay}" /></TextBlock>
                                        <TextBlock FontWeight="SemiBold" Margin="0,5,0,0"><Run Text="✓ " /><Run Text="{Binding AboutCookiesText, Mode=OneWay}" /></TextBlock>
                                        <TextBlock FontWeight="SemiBold" Margin="0,5,0,0"><Run Text="✓ " /><Run Text="{Binding AboutBrowserHistoryText, Mode=OneWay}" /></TextBlock>
                                        <TextBlock FontWeight="SemiBold" Margin="0,5,0,0"><Run Text="✓ " /><Run Text="{Binding AboutEmailsText, Mode=OneWay}" /></TextBlock>
                                        <TextBlock FontWeight="SemiBold" Margin="0,5,0,0"><Run Text="✓ " /><Run Text="{Binding AboutPersonalFilesText, Mode=OneWay}" /></TextBlock>
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFFFFF" BorderBrush="{StaticResource ZenStrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="22" Margin="0,0,0,16" Effect="{StaticResource CardShadow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding AboutSecurityTitleText}" FontSize="20" FontWeight="Bold" />
                                        <TextBlock FontWeight="SemiBold" Margin="0,18,0,0"><Run Text="✓ " /><Run Text="{Binding AboutITModeProtectedText, Mode=OneWay}" /></TextBlock>
                                        <TextBlock FontWeight="SemiBold" Margin="0,8,0,0"><Run Text="✓ " /><Run Text="{Binding AboutLocalExecutionOnlyText, Mode=OneWay}" /></TextBlock>
                                        <TextBlock FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap"><Run Text="✓ " /><Run Text="{Binding AboutSupportPackagesExcludePersonalDataText, Mode=OneWay}" /></TextBlock>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Style="{StaticResource CardStyle}"
                            Padding="42"
                            Margin="0,24,0,0"
                            MinHeight="420"
                            Visibility="{Binding IsGenericPlaceholderSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="480">
                            <Border Width="64"
                                    Height="64"
                                    CornerRadius="22"
                                    Background="#E7FBFA"
                                    BorderBrush="#BEEDEA"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="{Binding SelectedNavigationItem.IconText}"
                                           Foreground="{StaticResource ZenTealDarkBrush}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{Binding SelectedNavigationItem.Title}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       Margin="0,20,0,8" />
                            <TextBlock Text="{Binding PlaceholderText}"
                                       FontSize="15"
                                       LineHeight="23"
                                       Foreground="{StaticResource ZenMutedBrush}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="2"
                               Text="{Binding FooterText}"
                               Foreground="{StaticResource ZenMutedBrush}"
                               FontSize="12.5"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,22,0,0" />
                </Grid>
            </ScrollViewer>
        </Grid>

        <Border Grid.ColumnSpan="2"
                Background="#66000000"
                Visibility="{Binding IsConfirmationVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Style="{StaticResource CardStyle}"
                    Width="520"
                    Padding="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding ConfirmITWorkflowText}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource ZenNavyBrush}" />
                    <TextBlock Text="{Binding ConfirmationWorkflowName}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource ZenTealDarkBrush}"
                               Margin="0,14,0,0" />
                    <TextBlock Text="{Binding ConfirmationDescription}"
                               FontSize="14"
                               Foreground="{StaticResource ZenMutedBrush}"
                               TextWrapping="Wrap"
                               LineHeight="21"
                               Margin="0,8,0,0" />
                    <UniformGrid Columns="2" Margin="0,18,0,0">
                        <Border Background="#FFF9EE" BorderBrush="#F5A623" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding RiskLevelText}" Foreground="{StaticResource ZenMutedBrush}" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ConfirmationRiskLevel}" Foreground="#F5A623" FontWeight="Bold" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="#F7FBFE" BorderBrush="{StaticResource ZenStrokeBrush}" BorderThickness="1" CornerRadius="14" Padding="12" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding PermissionsText}" Foreground="{StaticResource ZenMutedBrush}" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ConfirmationAdminText}" Foreground="{StaticResource ZenNavyBrush}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                    <Grid Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding LoggedNoticeText}"
                                   Foreground="{StaticResource ZenMutedBrush}"
                                   FontSize="12.5"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                        <Button Grid.Column="1"
                                Content="{Binding CancelText}"
                                Command="{Binding CancelRunCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Background="#EEF6FF"
                                Foreground="{StaticResource ZenNavyBrush}"
                                Margin="16,0,8,0" />
                        <Button Grid.Column="2"
                                Content="{Binding ConfirmationContinueText}"
                                Command="{Binding ConfirmRunCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.Column="1"
                Background="{Binding ToastBrush}"
                CornerRadius="18"
                Padding="18,12"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,22,34,0"
                Visibility="{Binding IsToastVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{Binding ToastMessage}"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="13.5"
                       TextWrapping="Wrap"
                       MaxWidth="360" />
        </Border>
    </Grid>
</Window>
