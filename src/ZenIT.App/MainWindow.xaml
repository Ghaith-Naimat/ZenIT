                                                     FontSize="15"
                                                     Padding="12,8"
                                                     BorderBrush="{StaticResource ZenStrokeBrush}"
                                                     BorderThickness="1"
                                                     IsEnabled="{Binding IsITModePolicyAvailable}"
                                                     Margin="0,0,0,14" />
                                            <TextBlock Text="{Binding ITPasswordText}"
                                                       Foreground="{StaticResource ZenMutedBrush}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6" />
                                            <Grid>
                                                <PasswordBox x:Name="UnlockPasswordBox"
                                                             Tag="Unlock"
                                                             PasswordChanged="ItPasswordBox_OnPasswordChanged"
                                                             Height="44"
                                                             FontSize="15"
                                                             Padding="12,8"
                                                             BorderBrush="{StaticResource ZenStrokeBrush}"
                                                             BorderThickness="1"
                                                             IsEnabled="{Binding IsITModePolicyAvailable}" />
