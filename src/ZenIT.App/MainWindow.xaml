                                                         FontSize="15"
                                                         Padding="12,8"
                                                         BorderBrush="{StaticResource ZenStrokeBrush}"
                                                         BorderThickness="1"
                                                         IsEnabled="{Binding IsITModePolicyAvailable}"
                                                         Visibility="Collapsed" />
